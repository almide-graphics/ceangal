// scroll_test — multi-region scroll engine tests

import self.scroll as s

fn approx(a: Float, b: Float, tol: Float) -> Bool =
  float.abs(a - b) < tol

// ── Region setup ──

test "create_region sets bounds" {
  s.reset_all()
  let id = s.create_region(1000.0, 2000.0, 500.0, 500.0, 0 - 1)
  assert(id == 0)
  assert(s.get_min(0, 0) == -1500.0) // Y: -(2000-500)
  assert(s.get_min(0, 1) == -500.0)  // X: -(1000-500)
}

test "create_region no scroll when content fits" {
  s.reset_all()
  let _ = s.create_region(100.0, 100.0, 200.0, 200.0, 0 - 1)
  assert(s.get_min(0, 0) == 0.0)
  assert(s.get_min(0, 1) == 0.0)
}

// ── Single-axis consume ──

test "consume returns remainder at bounds" {
  s.reset_all()
  let _ = s.create_region(100.0, 1000.0, 100.0, 500.0, 0 - 1)
  // min_y = -500. Consume -600 from 0 → clamped to -500, remainder = -100
  let rem = s.consume(s.ax(0, 0), -600.0)
  assert(approx(s.get_pos(0, 0), -500.0, 0.1))
  assert(approx(rem, -100.0, 0.1))
}

test "consume returns 0 when within bounds" {
  s.reset_all()
  let _ = s.create_region(100.0, 1000.0, 100.0, 500.0, 0 - 1)
  let rem = s.consume(s.ax(0, 0), -200.0)
  assert(approx(s.get_pos(0, 0), -200.0, 0.1))
  assert(approx(rem, 0.0, 0.1))
}

// ── Wheel routing ──

test "route_wheel moves region" {
  s.reset_all()
  let _ = s.create_region(100.0, 2000.0, 100.0, 500.0, 0 - 1)
  s.route_wheel(0, 0.0, -50.0)
  assert(approx(s.get_pos(0, 0), -50.0, 0.1))
  assert(s.get_state(0, 0) == 1) // COASTING
  assert(s.get_bar_opacity(0, 0) == 1.0)
}

test "route_wheel overscroll triggers bouncing" {
  s.reset_all()
  let _ = s.create_region(100.0, 100.0, 100.0, 100.0, 0 - 1)
  s.route_wheel(0, 0.0, 10.0) // overscroll past top
  // consume clamps to 0, but wheel still sets velocity → COASTING or BOUNCING
  assert(s.get_state(0, 0) != 0)
}

// ── Nested bubble ──

test "nested scroll bubbles remainder to parent" {
  s.reset_all()
  // Root: 200vh content
  let root = s.create_region(500.0, 1000.0, 500.0, 500.0, 0 - 1)
  // Inner: 150vh content, inside root at (0, 100)
  let inner = s.create_region(500.0, 750.0, 500.0, 500.0, root)
  s.set_bounds(inner, 0.0, 100.0, 500.0, 500.0)
  // Scroll inner to bottom: min_y = -(750-500) = -250
  s.set_pos(inner, 0, -250.0)
  // Now wheel down on inner — should bubble to root
  s.route_wheel(inner, 0.0, -100.0)
  // Inner is at min (-250), can't consume more → bubbles to root
  assert(s.get_pos(root, 0) < 0.0)
}

test "nested scroll inner consumes before bubble" {
  s.reset_all()
  let root = s.create_region(500.0, 1000.0, 500.0, 500.0, 0 - 1)
  let inner = s.create_region(500.0, 750.0, 500.0, 500.0, root)
  // Inner at top, plenty of room to scroll
  s.route_wheel(inner, 0.0, -100.0)
  // Inner should consume all, root stays at 0
  assert(approx(s.get_pos(inner, 0), -100.0, 0.1))
  assert(s.get_pos(root, 0) == 0.0)
}

// ── Hit test ──

test "hit_test returns innermost region" {
  s.reset_all()
  let root = s.create_region(1000.0, 1000.0, 500.0, 500.0, 0 - 1)
  let inner = s.create_region(500.0, 750.0, 300.0, 300.0, root)
  s.set_bounds(inner, 50.0, 50.0, 300.0, 300.0)
  // Point inside inner region
  assert(s.hit_test(100.0, 100.0) == inner)
  // Point outside inner but inside root
  assert(s.hit_test(400.0, 400.0) == root)
}

// ── Tick: coasting ──

test "tick coasting decays velocity" {
  s.reset_all()
  let _ = s.create_region(100.0, 2000.0, 100.0, 500.0, 0 - 1)
  s.set_pos(0, 0, -100.0)
  s.set_vel(0, 0, -500.0)
  s.set_state(0, 0, 1) // COASTING
  let before = s.get_vel(0, 0)
  let _ = s.tick_all(0.016)
  assert(float.abs(s.get_vel(0, 0)) < float.abs(before))
}

test "tick bouncing returns to boundary" {
  s.reset_all()
  let _ = s.create_region(100.0, 200.0, 100.0, 200.0, 0 - 1)
  s.set_pos(0, 0, 50.0) // overscrolled past top
  s.set_state(0, 0, 2) // BOUNCING
  for _ in 0..200 { let _ = s.tick_all(0.016) }
  assert(approx(s.get_pos(0, 0), 0.0, 1.0))
  assert(s.get_state(0, 0) == 0) // IDLE
}

// ── Scrollbar geometry ──

test "thumb_info correct size and position" {
  s.reset_all()
  let _ = s.create_region(100.0, 1000.0, 100.0, 500.0, 0 - 1)
  let t = s.thumb_info(s.ax(0, 0), 500.0, 1000.0)
  assert(approx(t.size, 250.0, 1.0))
  assert(approx(t.pos, 0.0, 1.0))
}

test "thumb_info at bottom" {
  s.reset_all()
  let _ = s.create_region(100.0, 1000.0, 100.0, 500.0, 0 - 1)
  s.set_pos(0, 0, -500.0)
  let t = s.thumb_info(s.ax(0, 0), 500.0, 1000.0)
  assert(approx(t.pos, 250.0, 1.0))
}

test "thumb_info no scroll returns zero" {
  s.reset_all()
  let _ = s.create_region(100.0, 100.0, 100.0, 100.0, 0 - 1)
  let t = s.thumb_info(s.ax(0, 0), 100.0, 100.0)
  assert(t.size == 0.0)
}

// ── Track tap ──

test "track_tap jumps to position" {
  s.reset_all()
  let _ = s.create_region(100.0, 1000.0, 100.0, 500.0, 0 - 1)
  s.track_tap(s.ax(0, 0), 250.0, 500.0, 1000.0)
  assert(approx(s.get_pos(0, 0), -250.0, 1.0))
}

// ── Scrollbar fade ──

test "scrollbar fades after idle" {
  s.reset_all()
  let _ = s.create_region(100.0, 1000.0, 100.0, 500.0, 0 - 1)
  s.route_wheel(0, 0.0, -10.0)
  assert(s.get_bar_opacity(0, 0) == 1.0)
  s.set_state(0, 0, 0) // force IDLE
  s.set_vel(0, 0, 0.0)
  for _ in 0..82 { let _ = s.tick_all(0.016) }
  assert(s.get_bar_opacity(0, 0) < 1.0)
  for _ in 0..50 { let _ = s.tick_all(0.016) }
  assert(s.get_bar_opacity(0, 0) < 0.02)
}

// ── Full cycle ──

test "wheel coast stop cycle" {
  s.reset_all()
  let _ = s.create_region(100.0, 2000.0, 100.0, 500.0, 0 - 1)
  s.route_wheel(0, 0.0, -30.0)
  var running = 1
  var ticks = 0
  while running == 1 and ticks < 500 {
    running = s.tick_all(0.016)
    ticks = ticks + 1
  }
  assert(s.get_state(0, 0) == 0)
  assert(s.get_pos(0, 0) < 0.0)
  assert(float.abs(s.get_vel(0, 0)) < 0.5)
}

// ── powf ──

test "powf computes float exponentiation" {
  assert(approx(s.powf(2.0, 3.0), 8.0, 0.001))
  assert(approx(s.powf(0.95, 60.0), 0.0461, 0.001))
  assert(approx(s.powf(10.0, 0.0), 1.0, 0.001))
}
