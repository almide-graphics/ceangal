// render pipeline tests

import self.view as v
import self.render as r

fn approx(a: Float, b: Float) -> Bool = float.abs(a - b) < 1.0

test "text renders to single item" {
  let view = v.text("hello") |> v.font(20.0)
  let items = r.render(view, 400.0, 300.0)
  assert(list.len(items) >= 1)
  assert(items[0].content == "hello")
}

test "col renders children" {
  let view = v.col([
    v.text("A") |> v.padding(8.0),
    v.text("B") |> v.padding(8.0),
  ]) |> v.gap(4.0) |> v.padding(16.0)
  let items = r.render(view, 400.0, 300.0)
  // col + 2 children = 3 items
  assert(list.len(items) == 3)
}

test "bg color preserved" {
  let red = v.rgba(1.0, 0.0, 0.0, 1.0)
  let view = v.text("red") |> v.bg(red)
  let items = r.render(view, 400.0, 300.0)
  assert(items[0].bg_r == 1.0)
  assert(items[0].bg_g == 0.0)
}

test "children positioned vertically in col" {
  let view = v.col([
    v.text("A") |> v.h(50.0),
    v.text("B") |> v.h(50.0),
  ])
  let items = r.render(view, 400.0, 300.0)
  // items[0] = col, items[1] = A, items[2] = B
  assert(items[1].y < items[2].y)
}

test "todo app renders" {
  let blue = v.rgba(0.2, 0.4, 0.9, 1.0)
  let view = v.col([
    v.text("Todos (2)") |> v.font(28.0),
    v.col([
      v.text("Buy milk") |> v.padding(12.0),
      v.text("Write docs") |> v.padding(12.0),
    ]) |> v.gap(4.0),
    v.text("+ Add") |> v.bg(blue) |> v.padding(12.0),
  ]) |> v.gap(8.0) |> v.padding(16.0)

  let items = r.render(view, 800.0, 600.0)
  assert(list.len(items) >= 5)
  // Last item should have blue bg
  let add_btn = items[list.len(items) - 1]
  assert(add_btn.bg_b > 0.8)
}
